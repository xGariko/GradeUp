{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/GradeUp/browser",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/GradeUp/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gradeup-production-0e60.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
